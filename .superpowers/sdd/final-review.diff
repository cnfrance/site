+  { titre: "Aviron santé", desc: "Une pratique douce et encadrée, adaptée à chacun.", href: "/pratiquer/aviron-sante" },
+  { titre: "Découverte", desc: "Séances d'initiation et stages pour débuter l'aviron.", href: "/pratiquer/stages-decouverte" },
