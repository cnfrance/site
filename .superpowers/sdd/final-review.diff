+        </a>
+      ))}
+    </div>
+  </div>
+</section>
+<style>
+  .disc { padding-block: 3.5rem; background: var(--blanc); }
+  .disc__h { font-size: clamp(1.6rem, 3.5vw, 2.4rem); margin-bottom: 1.8rem; }
