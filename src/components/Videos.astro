---
interface Video { lien?: string; fichier?: string; titre?: string; }
interface Props { videos?: Video[]; }
const { videos = [] } = Astro.props;

// Transforme un lien YouTube / Vimeo en URL d'intégration (embed).
function embed(url: string): string | null {
  let m = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/|shorts\/|live\/))([\w-]{11})/);
  if (m) return `https://www.youtube.com/embed/${m[1]}`;
  m = url.match(/vimeo\.com\/(?:video\/)?(\d+)/);
  if (m) return `https://player.vimeo.com/video/${m[1]}`;
  return null;
}
const items = videos.filter((v) => v.lien || v.fichier);
---
{items.length > 0 && (
  <div class="videos">
    {items.map((v) => {
      const emb = v.lien ? embed(v.lien) : null;
      return (
        <figure class="videos__item">
          {emb ? (
            <div class="videos__frame">
              <iframe src={emb} title={v.titre || "Vidéo"} loading="lazy" allowfullscreen
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
            </div>
          ) : v.fichier ? (
            <video class="videos__video" src={v.fichier} controls preload="metadata"></video>
          ) : (
            <a href={v.lien} target="_blank" rel="noopener">{v.titre || v.lien}</a>
          )}
          {v.titre && <figcaption>{v.titre}</figcaption>}
        </figure>
      );
    })}
  </div>
)}
<style>
  .videos { display: grid; gap: 1.4rem; margin-block: 1.6rem; }
  .videos__item { margin: 0; }
  .videos__frame { position: relative; aspect-ratio: 16 / 9; border-radius: 12px; overflow: hidden; background: #000; }
  .videos__frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .videos__video { width: 100%; border-radius: 12px; background: #000; display: block; }
  .videos figcaption { font-size: 0.9rem; color: var(--muted); margin-top: 0.4rem; text-align: center; }
</style>
