---
// Structure calquée VERBATIM sur la navigation de l'ancien site (libellés et
// ordre), avec les URLs pointant vers les pages migrées sur ce site.
// `court` = libellé compact affiché dans la barre desktop (le libellé complet
// reste utilisé dans le tiroir mobile et l'attribut title).
const rubriques = [
  {
    label: "Le club",
    href: "/le-club/notre-club-centre-nautique-de-paris",
    sousMenu: [
      { label: "Activités et historique", href: "/le-club/notre-club-centre-nautique-de-paris" },
      { label: "Nos valeurs", href: "/le-club/nos-valeurs" },
      { label: "Encadrement", href: "/le-club/encadrement" },
      { label: "Équipements", href: "/le-club/equipements" },
      { label: "Règlement intérieur & statuts", href: "/le-club/reglement-interieur-statuts" },
      { label: "Médiathèque", href: "/le-club/mediatheque" },
    ],
  },
  {
    label: "Infos Pratiques",
    href: "/infos-pratiques/horaires",
    sousMenu: [
      { label: "Horaires", href: "/infos-pratiques/horaires" },
      { label: "Tarifs", href: "/infos-pratiques/tarifs" },
      { label: "Adhérer au CNF", href: "/infos-pratiques/adherez-au-cnf" },
      { label: "Plan de navigation général", href: "/infos-pratiques/plan-de-navigation-general" },
      { label: "Info Seine", href: "/infos-pratiques/info-seine" },
      { label: "Brevets & diplômes", href: "/infos-pratiques/brevets-diplomes" },
      { label: "Calendrier", href: "/infos-pratiques/calendrier" },
    ],
  },
  {
    label: "Pratiquer",
    href: "/pratiquer/aviron-competition",
    sousMenu: [
      { label: "Aviron Compétition", href: "/pratiquer/aviron-competition" },
      { label: "Aviron Loisirs", href: "/pratiquer/aviron-loisirs" },
      { label: "Aviron Indoor", href: "/pratiquer/aviron-in-door" },
      { label: "Aviron santé", href: "/pratiquer/aviron-sante" },
    ],
  },
  {
    label: "Découvrir",
    href: "/pratiquer/randonnees",
    sousMenu: [
      { label: "Randonnées", href: "/pratiquer/randonnees" },
      { label: "Stages découverte", href: "/pratiquer/stages-decouverte" },
    ],
  },
  {
    label: "Espace adhérents",
    href: "/espace-adherents/renouveler-son-adhesion2",
    sousMenu: [
      { label: "Renouveler mon inscription", href: "/espace-adherents/renouveler-son-adhesion2" },
      { label: "Bon usage du matériel", href: "/espace-adherents/du-bon-usage-du-materiel" },
      { label: "Sécurité & navigation", href: "/espace-adherents/securite-navigation" },
      { label: "Résultats", href: "/resultats" },
      { label: "Actualités", href: "/actualites" },
      { label: "Ligne Vestimentaire", href: "/espace-adherents/ligne-vestimentaire" },
      { label: "Formation / Perfectionnement", href: "/espace-adherents/formation-perfectionnement" },
      { label: "Faire un don", href: "/espace-adherents/faire-un-don" },
    ],
  },
  {
    label: "Partenariat",
    href: "/partenariat/aviron-comites-d-entreprises",
    sousMenu: [
      { label: "Aviron Comités d'entreprises", href: "/partenariat/aviron-comites-d-entreprises" },
      { label: "Aviron universitaire", href: "/partenariat/aviron-universitaire" },
      { label: "Aviron scolaire", href: "/partenariat/aviron-scolaire" },
      { label: "Sponsors club", href: "/partenariat/sponsor" },
    ],
  },
  {
    label: "Team Building",
    href: "/partenariat/team-building",
    sousMenu: [],
  },
  {
    label: "150 Ans du Cercle Nautique de France",
    court: "150 ans",
    href: "/150-ans/150-ans",
    sousMenu: [
      { label: "Photos vidéos du week end 150 ans ICI", href: "/150-ans/photos-videos-du-week-end-150-ans-ici" },
      { label: "Grande soirée du 12 Juillet 2025", href: "/150-ans/grande-soiree-du-12-juillet-2025" },
      { label: "ROW 500 : 14 juillet spéciale 150 ans", href: "/150-ans/row-500-edition-speciale-150-ans" },
      { label: "Partenaires de la row 500", href: "/150-ans/sponsors-de-la-row-500" },
      { label: "Relais Indoor 21 juin 2025 : édition spéciale 150 ans", href: "/150-ans/relais-indoor-sur-100-km-21-juin-2025-edition-speciale-150-ans" },
      { label: "Histoire : 150 d'aviron", href: "/150-ans/histoire-150-d-aviron" },
      { label: "Boutique 150 ans cercle Nautique de France", href: "/150-ans/boutique" },
    ],
  },
];
---
<header class="nav" data-nav>
  <div class="nav__bar">
    <a class="nav__brand" href="/" aria-label="Accueil — Cercle Nautique de France">
      <img class="nav__logo" src="/images/brand/logo-cnf.png" width="48" height="48"
        alt="Cercle Nautique de France" />
      <span class="nav__word">
        <b>Cercle Nautique</b>
        <span>de France · 1875</span>
      </span>
    </a>

    <nav class="nav__desktop" aria-label="Navigation principale">
      <a class="nav__top" href="/">Accueil</a>
      {rubriques.map((r, i) => (
        r.sousMenu.length > 0 ? (
          <div class="nav__group" data-group>
            <button
              type="button"
              class="nav__top nav__top--btn"
              aria-expanded="false"
              aria-haspopup="true"
              aria-controls={`dd-${i}`}
              title={r.label}
              data-trigger
            >
              <span>{r.court ?? r.label}</span>
              <svg class="nav__chev" viewBox="0 0 10 6" width="10" height="6" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="nav__menu" id={`dd-${i}`} role="menu" aria-label={r.label}>
              {r.sousMenu.map((s) => <a role="menuitem" href={s.href}>{s.label}</a>)}
            </div>
          </div>
        ) : (
          <a class="nav__top" href={r.href}>{r.court ?? r.label}</a>
        )
      ))}
    </nav>

    <button type="button" class="nav__burger" aria-expanded="false" aria-controls="nav-drawer" aria-label="Ouvrir le menu" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__drawer" id="nav-drawer" data-drawer>
    <nav class="nav__drawer-inner wrap" aria-label="Navigation mobile">
      <a class="nav__m-link" href="/">Accueil</a>
      {rubriques.map((r, i) => (
        r.sousMenu.length > 0 ? (
          <div class="nav__m-group" data-m-group>
            <button type="button" class="nav__m-top" aria-expanded="false" aria-controls={`m-${i}`} data-m-trigger>
              <span>{r.label}</span>
              <svg class="nav__chev" viewBox="0 0 10 6" width="12" height="7" aria-hidden="true"><path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <div class="nav__m-sub" id={`m-${i}`}>
              {r.sousMenu.map((s) => <a href={s.href}>{s.label}</a>)}
            </div>
          </div>
        ) : (
          <a class="nav__m-link" href={r.href}>{r.label}</a>
        )
      ))}
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>("[data-nav]");
  if (header) {
    // Ombre au scroll
    const onScroll = () => header.classList.toggle("nav--scrolled", window.scrollY > 8);
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    // Dropdowns desktop (clic + clavier ; le survol est géré en CSS)
    const groups = Array.from(header.querySelectorAll<HTMLElement>("[data-group]"));
    const fermerGroupes = (sauf?: HTMLElement) => {
      groups.forEach((g) => {
        if (g === sauf) return;
        g.classList.remove("is-open");
        g.querySelector("[data-trigger]")?.setAttribute("aria-expanded", "false");
      });
    };
    groups.forEach((g) => {
      const t = g.querySelector<HTMLButtonElement>("[data-trigger]");
      t?.addEventListener("click", () => {
        const open = g.classList.toggle("is-open");
        t.setAttribute("aria-expanded", String(open));
        fermerGroupes(open ? g : undefined);
      });
    });
    document.addEventListener("click", (e) => {
      if (!(e.target as Node)?.parentElement) return;
      const inside = groups.some((g) => g.contains(e.target as Node));
      if (!inside) fermerGroupes();
    });

    // Tiroir mobile
    const burger = header.querySelector<HTMLButtonElement>("[data-burger]");
    const setDrawer = (open: boolean) => {
      header.classList.toggle("nav--open", open);
      burger?.setAttribute("aria-expanded", String(open));
      burger?.setAttribute("aria-label", open ? "Fermer le menu" : "Ouvrir le menu");
      document.documentElement.classList.toggle("no-scroll", open);
    };
    burger?.addEventListener("click", () => setDrawer(!header.classList.contains("nav--open")));

    // Accordéons mobile
    header.querySelectorAll<HTMLElement>("[data-m-group]").forEach((g) => {
      const t = g.querySelector<HTMLButtonElement>("[data-m-trigger]");
      t?.addEventListener("click", () => {
        const open = g.classList.toggle("is-open");
        t.setAttribute("aria-expanded", String(open));
      });
    });
    // Fermer le tiroir au clic sur un lien
    header.querySelectorAll<HTMLAnchorElement>(".nav__drawer a").forEach((a) =>
      a.addEventListener("click", () => setDrawer(false))
    );

    // Échap ferme tout ; repasser en desktop ferme le tiroir
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") { fermerGroupes(); setDrawer(false); }
    });
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1280) setDrawer(false);
    });

    // Lien actif
    const path = location.pathname.replace(/\/+$/, "") || "/";
    const marquer = (a: HTMLAnchorElement) => {
      const raw = a.getAttribute("href");
      if (raw == null) return false; // les triggers <button> n'ont pas de href
      const href = raw.replace(/\/+$/, "") || "/";
      if (href === path) { a.classList.add("is-active"); a.setAttribute("aria-current", "page"); return true; }
      return false;
    };
    header.querySelectorAll<HTMLAnchorElement>("a.nav__top, .nav__menu a").forEach(marquer);
    groups.forEach((g) => {
      const actif = Array.from(g.querySelectorAll<HTMLAnchorElement>(".nav__menu a")).some(
        (a) => (a.getAttribute("href")?.replace(/\/+$/, "") || "/") === path
      );
      if (actif) g.querySelector("[data-trigger]")?.classList.add("is-active");
    });
  }
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--blanc) 90%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--gris-bord);
    transition: box-shadow 0.2s ease, background 0.2s ease;
  }
  .nav--scrolled { box-shadow: 0 6px 24px rgba(42, 5, 5, 0.08); background: color-mix(in srgb, var(--blanc) 96%, transparent); }

  .nav__bar { display: flex; align-items: center; gap: 1rem; padding-block: 0.55rem; padding-inline: clamp(1rem, 3vw, 2.25rem); }

  /* Marque */
  .nav__brand { display: flex; align-items: center; gap: 0.7rem; flex-shrink: 0; }
  .nav__logo { width: 46px; height: 46px; object-fit: contain; display: block; }
  .nav__word { display: flex; flex-direction: column; line-height: 1.05; }
  .nav__word b { font-family: var(--font-titre); font-size: 1.02rem; letter-spacing: 0.01em; color: var(--texte); }
  .nav__word span { font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); }

  /* Barre desktop */
  .nav__desktop { margin-left: auto; display: flex; align-items: center; gap: 0.05rem; }
  .nav__top {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.26rem;
    padding: 0.45rem 0.5rem;
    font-family: var(--font-corps);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--texte);
    background: none;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 8px;
  }
  .nav__top::after {
    content: "";
    position: absolute;
    left: 0.5rem; right: 0.5rem; bottom: 0.28rem;
    height: 2px;
    background: var(--rouge);
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.18s ease;
  }
  .nav__top:hover { color: var(--rouge); }
  .nav__top:hover::after,
  .nav__top.is-active::after { transform: scaleX(1); }
  .nav__top.is-active { color: var(--rouge); }
  .nav__top:focus-visible { outline: 2px solid var(--rouge); outline-offset: 2px; }
  .nav__chev { transition: transform 0.2s ease; margin-top: 1px; }

  .nav__group { position: relative; }
  /* Les rubriques de droite ouvrent leur menu vers la gauche : sinon le
     panneau (même caché) dépasse le bord droit et crée un scroll horizontal. */
  .nav__desktop > *:nth-last-child(-n+4) .nav__menu { left: auto; right: 0; }
  .nav__group.is-open .nav__chev,
  .nav__group:hover .nav__chev { transform: rotate(180deg); }

  /* Menu déroulant */
  .nav__menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 0.55rem;
    min-width: 250px;
    display: flex;
    flex-direction: column;
    padding: 0.4rem;
    background: var(--blanc);
    border: 1px solid var(--gris-bord);
    border-radius: 14px;
    box-shadow: 0 16px 40px rgba(42, 5, 5, 0.14);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.16s ease, transform 0.16s ease, visibility 0.16s;
    z-index: 110;
  }
  /* Pont invisible survolable comblant l'espace entre l'entrée et le menu */
  .nav__menu::before { content: ""; position: absolute; top: -0.55rem; left: 0; right: 0; height: 0.55rem; }
  .nav__group:hover .nav__menu,
  .nav__group:focus-within .nav__menu,
  .nav__group.is-open .nav__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav__menu a {
    padding: 0.5rem 0.7rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--texte);
    white-space: nowrap;
  }
  .nav__menu a:hover,
  .nav__menu a:focus-visible,
  .nav__menu a.is-active { background: var(--fond); color: var(--rouge); }

  /* Burger (caché en desktop) */
  .nav__burger { display: none; margin-left: auto; flex-direction: column; justify-content: center; gap: 5px; width: 44px; height: 44px; padding: 10px; background: none; border: none; cursor: pointer; border-radius: 10px; }
  .nav__burger span { display: block; height: 2px; width: 100%; background: var(--texte); border-radius: 2px; transition: transform 0.22s ease, opacity 0.22s ease; }
  .nav__burger:focus-visible { outline: 2px solid var(--rouge); outline-offset: 2px; }

  /* Tiroir mobile (caché en desktop) */
  .nav__drawer { display: none; }

  /* Sur le desktop compact, l'écusson (qui contient déjà le nom du club)
     suffit : on masque le wordmark pour laisser la place aux 9 rubriques. */
  @media (min-width: 1280px) { .nav__word { display: none; } }

  /* ===== Responsive : bascule en menu burger sous 1280px ===== */
  @media (max-width: 1279px) {
    .nav__desktop { display: none; }
    .nav__burger { display: flex; }

    .nav__drawer {
      display: block;
      overflow: hidden;
      max-height: 0;
      border-top: 1px solid transparent;
      transition: max-height 0.28s ease, border-color 0.28s ease;
    }
    .nav--open .nav__drawer {
      max-height: calc(100dvh - 62px);
      overflow-y: auto;
      border-top-color: var(--gris-bord);
      background: var(--blanc);
    }
    .nav--open .nav__burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav--open .nav__burger span:nth-child(2) { opacity: 0; }
    .nav--open .nav__burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    .nav__drawer-inner { display: flex; flex-direction: column; padding-block: 0.5rem 1.2rem; }
    .nav__m-link, .nav__m-top {
      display: flex; align-items: center; justify-content: space-between;
      width: 100%;
      padding: 0.85rem 0.25rem;
      font-family: var(--font-corps);
      font-weight: 600;
      font-size: 1.02rem;
      color: var(--texte);
      background: none; border: none; cursor: pointer; text-align: left;
      border-bottom: 1px solid var(--gris-bord);
    }
    .nav__m-top .nav__chev { transition: transform 0.2s ease; }
    .nav__m-group.is-open .nav__m-top .nav__chev { transform: rotate(180deg); }
    .nav__m-group.is-open .nav__m-top { color: var(--rouge); }
    .nav__m-sub { overflow: hidden; max-height: 0; transition: max-height 0.28s ease; }
    .nav__m-group.is-open .nav__m-sub { max-height: 40rem; }
    .nav__m-sub a {
      display: block;
      padding: 0.6rem 0.25rem 0.6rem 1rem;
      font-size: 0.94rem;
      color: var(--muted);
      border-bottom: 1px solid color-mix(in srgb, var(--gris-bord) 60%, transparent);
    }
    .nav__m-sub a:hover, .nav__m-sub a:focus-visible { color: var(--rouge); }
    .nav__m-link:hover { color: var(--rouge); }
  }

  @media (max-width: 400px) {
    .nav__word { display: none; }
  }
</style>
