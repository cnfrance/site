---
const rubriques = [
  {
    label: "Le club",
    href: "/le-club/notre-club-centre-nautique-de-paris",
    sousMenu: [
      { label: "Notre club", href: "/le-club/notre-club-centre-nautique-de-paris" },
      { label: "Nos valeurs", href: "/le-club/nos-valeurs" },
      { label: "Encadrement", href: "/le-club/encadrement" },
      { label: "Équipements", href: "/le-club/equipements" },
      { label: "Médiathèque", href: "/le-club/mediatheque" },
      { label: "Règlement intérieur & statuts", href: "/le-club/reglement-interieur-statuts" },
    ],
  },
  {
    label: "Pratiquer",
    href: "/pratiquer/aviron-competition",
    sousMenu: [
      { label: "Aviron compétition", href: "/pratiquer/aviron-competition" },
      { label: "Aviron loisirs", href: "/pratiquer/aviron-loisirs" },
      { label: "Aviron indoor", href: "/pratiquer/aviron-in-door" },
      { label: "Aviron santé", href: "/pratiquer/aviron-sante" },
      { label: "Randonnées", href: "/pratiquer/randonnees" },
      { label: "Stages découverte", href: "/pratiquer/stages-decouverte" },
    ],
  },
  {
    label: "Infos pratiques",
    href: "/infos-pratiques/horaires",
    sousMenu: [
      { label: "Horaires", href: "/infos-pratiques/horaires" },
      { label: "Tarifs", href: "/infos-pratiques/tarifs" },
      { label: "Adhérer au CNF", href: "/infos-pratiques/adherez-au-cnf" },
      { label: "Brevets & diplômes", href: "/infos-pratiques/brevets-diplomes" },
      { label: "Nous trouver", href: "/infos-pratiques/nous-trouver" },
      { label: "Nous contacter", href: "/infos-pratiques/contacter-le-cercle-nautique-de-france" },
    ],
  },
  {
    label: "Actualités",
    href: "/actualites",
    sousMenu: [],
  },
  {
    label: "Résultats",
    href: "/resultats",
    sousMenu: [],
  },
  {
    label: "150 ans",
    href: "/150-ans/150-ans",
    sousMenu: [
      { label: "150 ans du CNF", href: "/150-ans/150-ans" },
      { label: "Histoire : 150 ans d'aviron", href: "/150-ans/histoire-150-d-aviron" },
      { label: "Row 500 — spéciale 150 ans", href: "/150-ans/row-500-edition-speciale-150-ans" },
      { label: "Boutique", href: "/150-ans/boutique" },
    ],
  },
  {
    label: "Partenariat",
    href: "/partenariat/sponsor",
    sousMenu: [
      { label: "Sponsors", href: "/partenariat/sponsor" },
      { label: "Comités d'entreprises", href: "/partenariat/aviron-comites-d-entreprises" },
      { label: "Aviron universitaire", href: "/partenariat/aviron-universitaire" },
      { label: "Aviron scolaire", href: "/partenariat/aviron-scolaire" },
      { label: "Team building", href: "/partenariat/team-building" },
    ],
  },
];
---
<header class="nav">
  <div class="wrap nav__inner">
    <a class="nav__brand" href="/">
      <span class="nav__logo">CNF</span>
      <span class="nav__name">Cercle Nautique de France</span>
    </a>
    <nav class="nav__links" aria-label="Navigation principale">
      {rubriques.map((r) => (
        r.sousMenu.length > 0 ? (
          <div class="nav__item">
            <a href={r.href} aria-haspopup="true">{r.label}</a>
            <div class="nav__dropdown">
              {r.sousMenu.map((s) => <a href={s.href}>{s.label}</a>)}
            </div>
          </div>
        ) : (
          <a href={r.href}>{r.label}</a>
        )
      ))}
      <a class="btn nav__cta" href="/infos-pratiques/adherez-au-cnf">Nous rejoindre</a>
    </nav>
  </div>
</header>
<style>
  .nav { position: sticky; top: 0; z-index: 100; background: color-mix(in srgb, var(--blanc) 92%, transparent); backdrop-filter: blur(8px); border-bottom: 1px solid var(--gris-bord); }
  .nav__inner { display: flex; align-items: center; gap: 1.5rem; padding-block: 0.6rem; }
  .nav__brand { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; }
  .nav__logo { width: 34px; height: 34px; border-radius: 50%; background: var(--rouge); color: var(--blanc); display: grid; place-items: center; font-family: var(--font-titre); font-size: 0.8rem; }
  .nav__name { font-family: var(--font-titre); font-size: 0.95rem; }
  .nav__links { margin-left: auto; display: flex; align-items: center; gap: 1.1rem; font-weight: 600; font-size: 0.92rem; }
  .nav__links > a:not(.btn):hover { color: var(--rouge); }

  .nav__item { position: relative; }
  .nav__item:hover .nav__dropdown,
  .nav__item:focus-within .nav__dropdown {
    display: flex;
  }
  .nav__item > a:hover { color: var(--rouge); }
  .nav__dropdown {
    display: none;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    background: var(--blanc);
    border: 1px solid var(--gris-bord);
    border-radius: var(--radius);
    box-shadow: 0 12px 28px rgba(42, 5, 5, 0.12);
    padding: 0.5rem 0;
    margin-top: 0.6rem;
    z-index: 110;
  }
  .nav__dropdown a {
    padding: 0.5rem 1rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .nav__dropdown a:hover,
  .nav__dropdown a:focus-visible {
    background: var(--fond);
    color: var(--rouge);
  }

  @media (max-width: 820px) {
    .nav__name { display: none; }
    .nav__links { gap: 0.7rem; font-size: 0.8rem; flex-wrap: wrap; }
    .nav__dropdown { position: static; box-shadow: none; margin-top: 0.3rem; border: none; padding-left: 0.5rem; }
  }
</style>
