---
interface Props {
  photos: string[];
  alt: string;
  ratio?: string;
  variant?: "full" | "mini";
  autoplay?: boolean;
  interval?: number;
}

const {
  photos,
  alt,
  ratio = "16 / 9",
  variant = "full",
  autoplay = true,
  interval = 5000,
} = Astro.props;
---

{photos.length > 0 && (
  <div
    class="carousel"
    data-carousel
    data-variant={variant}
    data-autoplay={autoplay && photos.length > 1 ? "true" : "false"}
    data-interval={interval}
    tabindex="0"
    role="group"
    aria-roledescription="carrousel"
    aria-label={alt}
  >
    <div class="carousel__viewport">
      <div class="carousel__track" data-carousel-track>
        {photos.map((photo, i) => (
          <img
            class="carousel__img"
            src={photo}
            alt={`${alt} — photo ${i + 1}/${photos.length}`}
            style={`aspect-ratio: ${ratio};`}
            loading={i === 0 ? "eager" : "lazy"}
            fetchpriority={i === 0 ? "high" : "auto"}
            decoding={i === 0 ? "sync" : "async"}
          />
        ))}
      </div>

      {photos.length > 1 && (
        <>
          <button type="button" class="carousel__btn carousel__btn--prev" data-carousel-prev aria-label="Image précédente">‹</button>
          <button type="button" class="carousel__btn carousel__btn--next" data-carousel-next aria-label="Image suivante">›</button>

          {autoplay && (
            <button
              type="button"
              class="carousel__play"
              data-carousel-play
              aria-label="Mettre en pause le défilement automatique"
              aria-pressed="false"
            >
              <span class="carousel__play-pause" aria-hidden="true">⏸</span>
              <span class="carousel__play-play" aria-hidden="true">▶</span>
            </button>
          )}

          {variant === "full" ? (
            <span class="carousel__counter" data-carousel-counter aria-hidden="true">1 / {photos.length}</span>
          ) : (
            <span class="carousel__dots" data-carousel-dots aria-hidden="true">
              {photos.map((_, i) => (
                <span class="carousel__dot" data-carousel-dot={i} data-active={i === 0 ? "true" : "false"}></span>
              ))}
            </span>
          )}
        </>
      )}
    </div>
  </div>
)}

<style>
  .carousel {
    position: relative;
    outline: none;
  }
  .carousel:focus-visible .carousel__viewport {
    outline: 2px solid var(--rouge, #c0392b);
    outline-offset: 2px;
  }
  .carousel__viewport {
    position: relative;
    border-radius: var(--radius, 12px);
    overflow: hidden;
  }
  .carousel__track {
    display: flex;
    width: 100%;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    /* pan-x : le swipe horizontal fait défiler le carrousel, le geste
       vertical laisse défiler la page (support tactile natif). */
    touch-action: pan-x;
    scrollbar-width: none;
  }
  .carousel__track::-webkit-scrollbar {
    display: none;
  }
  .carousel__img {
    flex: 0 0 100%;
    width: 100%;
    object-fit: cover;
    scroll-snap-align: center;
  }
  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease, opacity 0.2s ease;
  }
  .carousel__btn:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  .carousel__btn:focus-visible,
  .carousel__play:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }
  .carousel__btn--prev {
    left: 0.6rem;
  }
  .carousel__btn--next {
    right: 0.6rem;
  }
  .carousel__btn[hidden] {
    display: none;
  }
  [data-variant="mini"] .carousel__btn {
    width: 1.9rem;
    height: 1.9rem;
    font-size: 1.1rem;
  }
  /* Bouton lecture / pause du défilement automatique */
  .carousel__play {
    position: absolute;
    left: 0.6rem;
    bottom: 0.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border: none;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-size: 0.8rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .carousel__play:hover {
    background: rgba(0, 0, 0, 0.7);
  }
  [data-variant="mini"] .carousel__play {
    width: 1.6rem;
    height: 1.6rem;
    font-size: 0.65rem;
  }
  /* Par défaut (en lecture), on montre l'icône pause ; en pause on montre lecture */
  .carousel__play-play {
    display: none;
  }
  .carousel[data-paused="true"] .carousel__play-pause {
    display: none;
  }
  .carousel[data-paused="true"] .carousel__play-play {
    display: inline;
  }
  .carousel__counter {
    position: absolute;
    right: 0.7rem;
    bottom: 0.6rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 600;
  }
  .carousel__dots {
    position: absolute;
    left: 50%;
    bottom: 0.5rem;
    transform: translateX(-50%);
    display: flex;
    gap: 0.35rem;
  }
  .carousel__dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.55);
  }
  .carousel__dot[data-active="true"] {
    background: #fff;
  }
</style>

<script>
  const REDUCED = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  interface CarouselCtl { evaluate: () => void; }
  const controllers: CarouselCtl[] = [];

  function setupCarousel(root: HTMLElement) {
    const track = root.querySelector<HTMLElement>(".carousel__track");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-carousel-prev]");
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-carousel-next]");
    const playBtn = root.querySelector<HTMLButtonElement>("[data-carousel-play]");
    const counter = root.querySelector<HTMLElement>("[data-carousel-counter]");
    const dots = Array.from(root.querySelectorAll<HTMLElement>("[data-carousel-dot]"));
    const images = Array.from(root.querySelectorAll<HTMLImageElement>(".carousel__img"));
    if (!track || images.length === 0) return;

    const count = images.length;
    const wantsAutoplay = root.getAttribute("data-autoplay") === "true";
    const interval = Number(root.getAttribute("data-interval")) || 5000;

    function currentIndex() {
      const width = track!.clientWidth || 1;
      return Math.round(track!.scrollLeft / width);
    }

    function update() {
      const index = Math.min(Math.max(currentIndex(), 0), count - 1);
      const atStart = track!.scrollLeft <= 4;
      const atEnd = track!.scrollLeft >= track!.scrollWidth - track!.clientWidth - 4;
      if (prevBtn) prevBtn.hidden = atStart;
      if (nextBtn) nextBtn.hidden = atEnd;
      if (counter) counter.textContent = `${index + 1} / ${count}`;
      dots.forEach((dot, i) => dot.setAttribute("data-active", i === index ? "true" : "false"));
    }

    function go(dir: number) {
      track!.scrollBy({ left: dir * track!.clientWidth, behavior: "smooth" });
    }

    prevBtn?.addEventListener("click", () => go(-1));
    nextBtn?.addEventListener("click", () => go(1));

    root.addEventListener("keydown", (event) => {
      const e = event as KeyboardEvent;
      if (e.key === "ArrowLeft") { e.preventDefault(); go(-1); }
      else if (e.key === "ArrowRight") { e.preventDefault(); go(1); }
    });

    let ticking = false;
    track.addEventListener("scroll", () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => { update(); ticking = false; });
    });
    window.addEventListener("resize", update);
    update();

    // ---- Défilement automatique, pausable ----
    if (!wantsAutoplay) return;

    // État de pause : manuel (bouton) + interactions (survol/focus/tactile) + visibilité
    let userPaused = REDUCED;         // en reduced-motion, en pause par défaut
    let hovering = false;
    let focused = false;
    let touching = false;
    let visible = true;
    let timer: number | null = null;
    let touchResume: number | null = null;

    function shouldPlay() {
      return wantsAutoplay && !userPaused && !hovering && !focused
        && !touching && visible && !document.hidden && count > 1;
    }

    function advance() {
      const atEnd = track!.scrollLeft >= track!.scrollWidth - track!.clientWidth - 4;
      if (atEnd) track!.scrollTo({ left: 0, behavior: "smooth" });
      else go(1);
    }

    function evaluate() {
      const play = shouldPlay();
      if (play && timer === null) {
        timer = window.setInterval(advance, interval);
      } else if (!play && timer !== null) {
        window.clearInterval(timer);
        timer = null;
      }
      root.setAttribute("data-paused", userPaused ? "true" : "false");
      if (playBtn) {
        playBtn.setAttribute("aria-pressed", userPaused ? "true" : "false");
        playBtn.setAttribute(
          "aria-label",
          userPaused ? "Lancer le défilement automatique" : "Mettre en pause le défilement automatique"
        );
      }
    }

    controllers.push({ evaluate });

    // Pause au survol souris
    root.addEventListener("mouseenter", () => { hovering = true; evaluate(); });
    root.addEventListener("mouseleave", () => { hovering = false; evaluate(); });
    // Pause au focus clavier
    root.addEventListener("focusin", () => { focused = true; evaluate(); });
    root.addEventListener("focusout", () => { focused = false; evaluate(); });
    // Pause au toucher ; reprise quelques secondes après la fin du geste
    root.addEventListener("touchstart", () => {
      touching = true;
      if (touchResume !== null) { window.clearTimeout(touchResume); touchResume = null; }
      evaluate();
    }, { passive: true });
    root.addEventListener("touchend", () => {
      if (touchResume !== null) window.clearTimeout(touchResume);
      touchResume = window.setTimeout(() => { touching = false; evaluate(); }, 4000);
    }, { passive: true });

    // Bouton lecture/pause manuel (prioritaire ; WCAG 2.2.2)
    playBtn?.addEventListener("click", () => { userPaused = !userPaused; evaluate(); });

    // N'autoplay que lorsque le carrousel est visible à l'écran
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => { visible = entry.isIntersecting; evaluate(); });
      }, { threshold: 0.35 });
      io.observe(root);
    }

    evaluate();
  }

  function init() {
    document.querySelectorAll<HTMLElement>("[data-carousel]").forEach(setupCarousel);
    // La visibilité de l'onglet met tous les carrousels en pause/lecture
    document.addEventListener("visibilitychange", () => controllers.forEach((c) => c.evaluate()));
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }
</script>
