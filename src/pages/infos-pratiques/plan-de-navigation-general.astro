---
import PageLayout from "../../layouts/PageLayout.astro";
---
<PageLayout
  titre="Plan de navigation"
  section="Infos pratiques"
  chapo="Zones de navigation, sens de circulation, demi-tours, ponts et zones interdites sur la Seine autour du club."
  description="Le plan de navigation du Cercle Nautique de France : zones autorisées, zones interdites, demi-tours et ponts sur la Seine à Neuilly-sur-Seine."
>
  <p>Avant chaque sortie, respectez le plan de navigation en vigueur. Cliquez sur un élément de la carte pour afficher son nom. Utilisez les boutons <strong>+ / −</strong> ou la molette (après avoir cliqué sur la carte) pour zoomer.</p>

  <div id="plan-map" class="plan-map" role="application" aria-label="Carte du plan de navigation du CNF"></div>

  <p class="plan-note">La carte présente les zones autorisées, les <strong>zones interdites</strong>, les zones de pause, les demi-tours, les tracés de navigation et les ponts. En cas de doute, renseignez-vous auprès de l'encadrement.</p>
</PageLayout>

<style>
  .plan-map {
    width: 100%;
    height: min(74vh, 720px);
    min-height: 420px;
    border-radius: 14px;
    margin-block: 1.6rem;
    overflow: hidden;
    border: 1px solid var(--gris-bord);
    box-shadow: 0 10px 30px rgba(42, 5, 5, 0.08);
    background: #eef3f6;
    /* Isole la carte dans son propre contexte d'empilement : ses contrôles
       Leaflet (z-index jusqu'à 1000) restent alors sous la navbar sticky (z-index 100). */
    position: relative;
    z-index: 0;
    isolation: isolate;
  }
  .plan-note { font-size: 0.92rem; color: var(--muted); }
</style>

<script>
  import L from "leaflet";
  import "leaflet/dist/leaflet.css";

  const el = document.getElementById("plan-map");
  if (el) {
    const map = L.map(el, { scrollWheelZoom: false }).setView([48.888, 2.269], 14);

    const ign = (layer: string, fmt: string) =>
      L.tileLayer(
        `https://data.geopf.fr/wmts?SERVICE=WMTS&REQUEST=GetTile&VERSION=1.0.0&LAYER=${layer}&STYLE=normal&TILEMATRIXSET=PM&FORMAT=${fmt}&TILEMATRIX={z}&TILEROW={y}&TILECOL={x}`,
        { attribution: "IGN / Géoplateforme", maxZoom: 19 }
      );
    const planIgn = ign("GEOGRAPHICALGRIDSYSTEMS.PLANIGNV2", "image/png");
    const photo = ign("ORTHOIMAGERY.ORTHOPHOTOS", "image/jpeg");
    const osm = L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { maxZoom: 19, attribution: "© OpenStreetMap" });
    planIgn.addTo(map);
    L.control.layers({ "Plan IGN": planIgn, "Photo aérienne": photo, "OpenStreetMap": osm }, undefined, { collapsed: true }).addTo(map);

    const styleOf = (p: any) => {
      const o = p._umap_options ?? {}, s = p._style ?? {};
      const c = o.color || s.color || "#2b6cb0";
      return { color: c, weight: o.weight || s.weight || 3, opacity: o.opacity ?? s.opacity ?? 0.9, fillColor: o.fillColor || s.fillColor || c, fillOpacity: o.fillOpacity ?? 0.25 };
    };
    const toLatLngs = (coords: any): any => (typeof coords[0] === "number" ? L.latLng(coords[1], coords[0]) : coords.map(toLatLngs));

    const group = L.featureGroup().addTo(map);
    try {
      const fc = await (await fetch(`${import.meta.env.BASE_URL.replace(/\/$/, "")}/data/plan-navigation.geojson`, { cache: "no-store" })).json();
      fc.features.forEach((feature: any) => {
        const g = feature.geometry, st = styleOf(feature.properties);
        let layer: any;
        if (g.type === "Point") layer = L.circleMarker([g.coordinates[1], g.coordinates[0]], { radius: 6, color: st.color, weight: 2, fillColor: st.fillColor, fillOpacity: 0.9 });
        else if (g.type === "LineString") layer = L.polyline(toLatLngs(g.coordinates), st);
        else if (g.type === "Polygon" || g.type === "MultiPolygon") layer = L.polygon(toLatLngs(g.coordinates), st);
        else return;
        const nm = feature.properties.name, lay = feature.properties._layer;
        const titre = [nm, lay].filter(Boolean).join(" — ");
        if (titre) layer.bindPopup(titre);
        if (nm) layer.bindTooltip(nm, { direction: "top" });
        layer.addTo(group);
      });
      map.fitBounds(group.getBounds(), { padding: [24, 24] });
    } catch (e) {
      /* la carte reste centrée sur le club si le chargement échoue */
    }

    map.on("click", () => map.scrollWheelZoom.enable());
    map.on("mouseout", () => map.scrollWheelZoom.disable());
  }
</script>
