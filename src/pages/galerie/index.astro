---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import Carousel from "../../components/Carousel.astro";

// Galerie = mini-carrousels par événement (actualités et résultats), légendés par le nom
// de l'événement et pointant vers l'article correspondant (migration cnfrance.fr).
const [actualitesArr, resultatsArr] = await Promise.all([
  getCollection("actualites"),
  getCollection("resultats"),
]);

function toEvenement(e: (typeof actualitesArr)[number] | (typeof resultatsArr)[number], href: string) {
  const photos = e.data.photos ?? (e.data.image ? [e.data.image] : []);
  return { titre: e.data.titre, date: e.data.date, photos: photos.slice(0, 6), href };
}

const evenements = [
  ...actualitesArr.map((e) => toEvenement(e, `/actualites/${e.id}`)),
  ...resultatsArr.map((e) => toEvenement(e, `/resultats/${e.id}`)),
]
  .filter((e) => e.photos.length > 0)
  .sort((a, b) => b.date.getTime() - a.date.getTime());

const fmt = new Intl.DateTimeFormat("fr-FR", { day: "numeric", month: "long", year: "numeric", timeZone: "Europe/Paris" });
---
<PageLayout
  titre="En images"
  section="Galerie"
  chapo="Retrouvez en images les événements et sorties du club."
>
  <div class="grid">
    {evenements.map((e) => (
      <figure class="grid__item">
        <Carousel variant="mini" ratio="4 / 3" photos={e.photos} alt={e.titre} />
        <figcaption class="grid__legende">
          <a href={e.href}>{e.titre}</a> · {fmt.format(e.date)}
        </figcaption>
      </figure>
    ))}
  </div>
</PageLayout>
<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.4rem;
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
  }
  .grid__item { margin: 0; }
  .grid__legende {
    margin-top: 0.6rem;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .grid__legende a {
    font-weight: 700;
    color: var(--texte);
    text-decoration: none;
  }
  .grid__legende a:hover { color: var(--rouge); text-decoration: underline; }
</style>
